#!/usr/bin/env bash
#MISE description="Generate an LCOV coverage report for the Rust crate"
#MISE tools={"aqua:taiki-e/cargo-llvm-cov" = "latest"}

set -euo pipefail

cover_rust() {
  rustup component add llvm-tools-preview
  cargo llvm-cov --workspace --locked --lcov --output-path target/lcov.info
}

case "${1:-all}" in
  all|rust) cover_rust ;;
  *)        echo "usage: mise coverage [rust]" >&2; exit 2 ;;
esac

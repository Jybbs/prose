#!/usr/bin/env bash
#MISE description="Check the built site's off-site URLs with `lychee`"
#MISE dir="site"
#MISE depends=["press"]
#MISE tools={"aqua:lycheeverse/lychee" = "latest"}

SITE_HOST=$(grep -om1 'https://[^/<]*' dist/sitemap-index.xml | cut -d/ -f3)

lychee --no-progress --base-url "https://${SITE_HOST}" \
  --exclude "^https?://(www\.)?${SITE_HOST//./\\.}" \
  --exclude '^https://github\.com/Jybbs/prose/edit/' \
  dist

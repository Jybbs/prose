#!/usr/bin/env bash
#MISE description="Re-resolve every lockfile against its manifest"
#MISE sources=["site/package.json", "Cargo.toml", "pyproject.toml"]
#MISE outputs=["site/bun.lock", "Cargo.lock", "uv.lock"]
# Re-resolves each ecosystem's lockfile and prints a `git diff --stat`
# naming any lockfile that moved.

set -euo pipefail

(cd site && bun install)
cargo update --workspace
uv lock
git diff --stat site/bun.lock Cargo.lock uv.lock

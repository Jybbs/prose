#!/usr/bin/env bash
#MISE description="Generate coverage and upload it to Codecov for the Rust crate"
#MISE tools={"pipx:codecov-cli" = "latest"}

set -euo pipefail

case "${1:-all}" in
  all|rust) mise run coverage rust && codecovcli upload-process --flag rust --file target/lcov.info --sha "$SHA" ;;
  *)        echo "usage: mise upload [rust]" >&2; exit 2 ;;
esac

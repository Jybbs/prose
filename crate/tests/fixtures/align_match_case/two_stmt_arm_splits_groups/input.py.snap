---
source: tests/integration.rs
expression: output
input_file: tests/fixtures/align_match_case/two_stmt_arm_splits_groups/input.py
---
match credential.kind:
    case "apprenticeship": icon = "wrench"
    case "certification":
        icon = "scroll"
        notes.append("verified")
    case "program" : icon = "cap"
    case _         : icon = "blank"

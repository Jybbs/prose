---
import { renderInline } from '../lib/markdown/render'

interface Props {
  text: string
}

// Renders a runtime string carrying inline markdown through the build-time
// inline primitive, so backtick spans and the page-body plugins reach titles
// and messages the way a regex substitution never could.
const { text } = Astro.props
const html     = await renderInline(text)
---

<Fragment set:html={html} />

"""
A class carrying both annotated fields and methods, all declared
out of order, with missing blank-line spacing between methods.

Rules:
- alphabetize
- blank_lines
- align_colons
- align_equals
"""


class Service:

    host        : str   = "localhost"
    retry_count : int   = 3
    timeout     : float = 30.0

    def _cleanup(self):
        return None

    def restart(self):
        return self.shutdown()

    def shutdown(self):
        return self._cleanup()

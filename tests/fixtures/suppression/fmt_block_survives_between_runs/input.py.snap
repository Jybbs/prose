"""
A fmt: off / fmt: on block sits between two assignment runs that the
alignment rules would otherwise touch. The block survives verbatim while the
runs above and below it pad to their group widths.
"""

bar_baz = 3
foo     = 2
x       = 1

# fmt: off
short = 1
much_longer_name = 2
mid = 3
# fmt: on

a   = 1
bb  = 2
ccc = 3

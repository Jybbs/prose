def render(context, encoding, template):
    """
    Render a template against the provided context, applying the configured
    fallback when context is missing a key.

    Args:
        context  : Mapping of names to values.
        encoding : Output encoding.
        template : The compiled template.

    Returns:
        The rendered string in the requested encoding.
    """
    return template

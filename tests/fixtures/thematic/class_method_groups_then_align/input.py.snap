from collections import Counter
from typing      import Any


class Posting:

    company     : str   = "TBD"
    description : str   = ""
    salary      : float = 0.0
    title       : str   = "Untitled"

    def __init__(self):
        pass

    def __repr__(self):
        return f"Posting({self.title})"

    @property

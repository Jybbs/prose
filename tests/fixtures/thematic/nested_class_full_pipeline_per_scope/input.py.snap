---
source: tests/integration.rs
expression: output
input_file: tests/fixtures/thematic/nested_class_full_pipeline_per_scope/input.py
---
class Order:

    customer_id : str   = ""
    placed_on   : str   = ""
    total       : float = 0.0

    class LineItem:

        price    : float = 0.0
        quantity : int   = 1
        sku      : str   = ""

        def subtotal(self):
            return self.price * self.quantity

    def __repr__(self):
        return f"Order({self.customer_id})"

    def total_with_tax(self, rate):
        return self.total * (1 + rate)

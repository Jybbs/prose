"""
A signature that mixes positional parameters with `*args` and
`**kwargs`. Each variadic slot counts as one parameter for the count
trigger.
"""


def dispatch(
    target,
    palette,
    *args,
    layout,
    spread=None,
    **kwargs,
):
    return (target, palette, layout, spread, args, kwargs)
